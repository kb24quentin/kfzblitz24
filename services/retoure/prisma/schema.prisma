generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────
// RetoureCase — eine angemeldete Retoure
// ─────────────────────────────────────────────────────────────────────
model RetoureCase {
  id          String  @id @default(cuid())
  externalRef String? @unique // optional ext. ID für Shop-Anbindung

  /// Source-Channel — entscheidet wer den Refund-Webhook bekommt:
  /// "shopware" → Shopware-Plugin via HTTP-Webhook
  /// "amazon" / "ebay" / "direct" → manueller Admin-Workflow
  source      String  @default("direct")

  /// Shop-interne Order-ID — wird in allen Webhook-Payloads zurückgegeben
  /// damit der Shop seine Order-Records matchen kann (z. B. Shopware-UUID).
  orderId     String?

  /// Retoure-Kategorie:
  /// "widerruf" — §312g BGB, 14 Tage Frist, Standard-Flow
  /// "gewaehrleistung" — §437 BGB, 2 Jahre Frist, mit Antrag-PDF (V2)
  kategorie   String  @default("widerruf")

  /// Customer-Steuerstatus für Gutschrifts-Berechnung:
  /// "privat" — brutto (Default)
  /// "gewerbe_vorsteuer" — netto-Gutschrift (B2B mit Vorsteuer-Abzug)
  kundenstatus String @default("privat")

  /// Frist bis wann Customer das Paket abschicken muss.
  /// Bei Widerruf: 14 Tage nach Anmeldung. Bei Gewährleistung: 30 Tage.
  /// Cron prüft täglich und storniert abgelaufene Cases mit Status="angemeldet".
  eligibleUntil DateTime?

  /// V2 Gewährleistung: Fahrzeug-Daten (HSN/TSN/Fahrgestellnr/Erstzulassung etc.)
  /// JSON: { hsn, tsn, hersteller, typ, fahrgestellnr, erstzulassung, motorKennbuchstabe, hubraumCm3, leistungKw }
  vehicleDataJson String?

  /// V2 Gewährleistung: Spezifische Felder (Einbaudaten, Werkstattkosten, Erfolgs-Präferenz)
  /// JSON: { einbauDatum, ausbauDatum, kmEinbau, kmAusbau, werkstattkostenEur, beiAbgelehnt, beiErfolg, mangelBeschreibung }
  gewaehrJson String?

  /// Webisco-Gutschrift-Nummer nach Refund-Decision (z. B. "KG-2026-12345")
  gutschriftNr String?

  /// Final entschiedener Erstattungsbetrag (gefüllt nach Admin-Decision)
  tatsaechlicheErstattung Float?

  // Bestelldaten aus Webisco
  bestellnummer String  // KB24-...
  belegId       String? // numerisch (z.B. "243775570")
  belegnummer   String? // "A243775570"
  belegdatum    String? // YYYY-MM-DD

  // Kunden-Snapshot zum Zeitpunkt der Anmeldung
  customerAnrede   String?
  customerVorname  String?
  customerName     String?
  customerStrasse  String?
  customerPlz      String?
  customerOrt      String?
  customerEmail    String?
  customerTelefon  String?
  customerHandy    String?

  // Items + Reasons als JSON-Array
  // [{artikelnummer, beschreibung, hersteller, menge, grund, einzelpreis_brutto, gesamtpreis_brutto, einzelgewicht_g}, ...]
  itemsJson String @default("[]")

  /// Zusätzliche Tracking-Nummern für Multi-Paket-Szenarien.
  /// `customerTrackingNumber` bzw. `dhlTrackingNumber` bleibt das
  /// primäre Tracking; `additionalTrackings` speichert weitere Pakete
  /// die zur selben Retoure gehören (z. B. Kunde schickt 5 Items in
  /// 2 Paketen). JSON-Array von Strings: ["TR2", "TR3"].
  additionalTrackings String @default("[]")

  /// Full snapshot ALLER Positionen des Original-Belegs (was der Kunde
  /// bestellt hatte, nicht nur was er zurückschickt). Lazy populated:
  /// leer="[]" bis zum ersten Bedarf, dann gefüllt aus Webisco-
  /// `beleganfrage`. Genutzt vom PDA-Scan-Endpoint um zu unterscheiden
  /// ob ein gescannter EAN zu einem Artikel der Order gehört (= ok als
  /// Extra) oder ein Fremd-Artikel ist (= NOT OK, Fehlsendung).
  /// Schema: [{artikelnummer, hersteller, beschreibung}, ...]
  orderPositionsJson String @default("[]")

  // Geld
  warenwertBrutto             Float @default(0)
  labelFeeBrutto              Float @default(0)
  voraussichtlicheErstattung  Float @default(0)

  // Versand-Mode (gem. Beleg-Detektion bzw. Kundenwahl)
  // "sicher" — Sichere Rückgabe, Label kostenfrei
  // "standard" — Kunde trägt Versandkosten ODER zahlt 5,50 € für Label über uns
  shippingMode  String  @default("standard")
  /// Hat der Kunde im Portal das DHL-Label über uns angefordert (in beiden Modi).
  labelRequested Boolean @default(false)
  /// Wenn ja: Label wurde von uns erzeugt und kostet ihn 5,50 €
  /// (nur im Standard-Mode; bei Sichere Rückgabe gratis).
  labelPaid     Boolean @default(false)

  // dodajpaczke-DHL-Sendung
  dhlShipmentId      Int?
  dhlTrackingNumber  String?
  dhlRetoureIdc      String?
  /// Gewicht in kg, das wir an DHL gemeldet haben (inkl. 20% Puffer / 30kg Fallback).
  weightSentKg       Float?

  // Falls Kunde mit eigenem Label versendet (Phase 2):
  customerTrackingNumber String?

  // Status-Maschine
  // angemeldet → versandt → unterwegs → eingang_partner → pruefung → erstattet
  //                                                                  → abgelehnt
  //                                                                  → storniert
  status      String   @default("angemeldet")

  // Admin-Notizen
  adminNotes  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events RetoureEvent[]
  items  RetoureItem[]

  // SLA-Felder (gefüllt von Carrier-Polling bzw. Partner-Scan)
  /// Zeitpunkt an dem DHL "delivered" / "eingang_partner" gemeldet hat.
  carrierDeliveredAt  DateTime?
  /// Zeitpunkt an dem ein Partner-PDA das Paket physisch gescannt hat.
  partnerReceivedAt   DateTime?
  /// Zeitpunkt an dem der Lager-Mitarbeiter "Fertig mit Scannen" tappt.
  /// Ohne diesen Wert bleibt der PDA-Wizard im SCAN-Step — auch wenn
  /// alle angemeldeten Items schon received sind — damit der Mitarbeiter
  /// noch nicht-angemeldete Extras (ok_extra) oder Falschsendungen
  /// (not_ok_unknown) scannen kann. Erst mit explizitem Tap geht's
  /// in den ASSESS-Step.
  scanCompletedAt     DateTime?
  /// Wenn DHL geliefert ist aber Partner noch nicht gescannt hat → SLA-Stunden.
  /// Sobald > slaThresholdHours, kommt der Case in die 9-Uhr-Mail.

  @@index([status])
  @@index([bestellnummer])
  @@index([dhlTrackingNumber])
  @@index([createdAt])
  @@index([carrierDeliveredAt])
  @@index([partnerReceivedAt])
}

// ─────────────────────────────────────────────────────────────────────
// RetoureItem — Item-Level Tracking
// ─────────────────────────────────────────────────────────────────────
model RetoureItem {
  id     String @id @default(cuid())
  caseId String

  /// "registered" — vom Kunden bei der Anmeldung markiert
  /// "extra"      — vom Lager im Paket gefunden, aber zur selben Order
  /// "unknown"    — vom Lager im Paket gefunden, NICHT zur Order (Wrong-Item)
  source String @default("registered")

  /// "pending"          — angemeldet, noch nicht gescannt
  /// "received"         — Partner-PDA hat es gescannt + bestätigt
  /// "missing"          — angemeldet aber nicht im Paket
  /// "photographed"     — Fotos aufgenommen
  /// "assessed"         — Mitarbeiter + AI-Score liegt vor
  /// "on_pallet"        — auf einen Container/Palette gelegt
  /// "shipped_supplier" — an Lieferanten retourniert
  /// "at_supplier"      — beim Lieferanten eingegangen
  /// "refunded"         — erstattet
  /// "rejected"         — abgelehnt
  status String @default("pending")

  // Snapshot zum Zeitpunkt der Anmeldung bzw. des Extra-Hinzufügens
  artikelnummer       String?
  hersteller          String?
  beschreibung        String?
  menge               Int     @default(1)
  /// Bei source=registered Pflicht; bei extra/unknown vom PDA gewählt.
  /// Freitext (legacy). Bei neuen Cases parallel zu grundCode/grundFreitext.
  grund               String?
  /// Standardisierter Rückgabe-Grund-Code (siehe lib/return-reasons.ts):
  /// passt_nicht_zum_fahrzeug | customer_reue | defekt | falsche_lieferung |
  /// beschaedigt_transport | qualitaet | anderes
  grundCode           String?
  /// Zusätzlicher Freitext zum Grund (bei grundCode=anderes Pflicht).
  grundFreitext       String?
  /// True wenn Retoure unser Verschulden ist (z. B. falsche_lieferung).
  /// Auswertbar für interne KPI „Eigen-Fehlerquote". Kein Refund-Impact.
  internalFault       Boolean @default(false)
  /// Final entschiedener Erstattungsbetrag pro Item (nach Admin-Decision).
  /// Null bis Refund freigegeben wurde.
  erstattungsbetragBrutto Float?
  einzelpreis_brutto  Float?
  gesamtpreis_brutto  Float?
  einzelgewicht_g     Int?
  /// EK-Preis brutto aus Webisco (Phase 8) — null bis das eingebaut ist.
  einkaufspreis_brutto Float?

  // Receive-Tracking
  receivedAt    DateTime?
  receivedByPda String? // device-token / user-email des PDA-Scanners
  scanCount     Int      @default(0)

  // Bewertung (Phase 5)
  employeeScore   Int? // 0–100, Mitarbeiter-Einschätzung
  aiScore         Int? // 0–100, OpenAI-Vision-Score
  combinedScore   Int? // gewichteter Score
  verdict         String? // "green" | "yellow" | "red"
  verdictReason   String?
  scoredAt        DateTime?

  // Photos (Phase 5)
  photoCount Int @default(0)

  // Container (Phase 6)
  containerId String?

  // Lieferanten-Bindung (Phase 6-Erweiterung):
  // - `einspeiserid` ist der Snapshot aus Webisco-Position. Achtung: das
  //   ist die **TecDoc-Einspeiser-ID des Artikels** (= Hersteller-ID,
  //   z. B. BMW/MANN/Osram), NICHT der Distributor (Interparts/Autopartner).
  //   Wir speichern den Wert trotzdem als Snapshot — Hersteller-Pivots
  //   ("welche Marke wird am meisten zurückgeschickt?") nutzen das.
  // - `supplierId` ist der eigentliche Distributor (Interparts vs
  //   Autopartner). Webisco liefert das nicht pro Position; gefüllt
  //   wird das erst beim "Item auf Container legen" — der Container hat
  //   den Supplier (PDA-Mitarbeiter wählt beim Anlegen), und das Item
  //   erbt ihn.
  einspeiserid Int?
  supplierId   String?

  /// EAN/GTIN-Code des Artikels — gefetched via Webisco-`artikelanfrage`
  /// beim ersten PDA-Lookup. Wird verwendet damit der Mitarbeiter den
  /// Artikel-Barcode mit dem Q900 scannen kann statt manuell "Da/Fehlt"
  /// zu drücken. Optional, weil Webisco nicht für jeden Artikel einen
  /// EAN führt (Sammelartikel, Hersteller-Pakete etc.) — Fallback ist
  /// dann die manuelle Bestätigung im PDA.
  eanCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case      RetoureCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  container Container?  @relation(fields: [containerId], references: [id], onDelete: SetNull)
  supplier  Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  photos    RetoureItemPhoto[]

  @@index([caseId])
  @@index([status])
  @@index([source])
  @@index([containerId])
  @@index([verdict])
  @@index([einspeiserid])
  @@index([supplierId])
  @@index([eanCode])
}

// ─────────────────────────────────────────────────────────────────────
// RetoureEvent — Timeline-Eintrag
// ─────────────────────────────────────────────────────────────────────
model RetoureEvent {
  id        String   @id @default(cuid())
  caseId    String
  /// "case_created" | "status_change" | "carrier_event" | "note" |
  /// "label_generated" | "label_failed" | "abisco_bemerkung_written" |
  /// "admin_action" | "tracking_added"
  type      String
  message   String?
  /// JSON-Metadaten (z.B. Carrier-Event-Code, old/new status, etc.)
  meta      String?
  actor     String?  // "system" | "admin" | "customer" | <user.id>
  createdAt DateTime @default(now())

  case RetoureCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([type])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────
// User — Admin-Login fürs Dashboard (NextAuth credentials)
// ─────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hash
  role      String   @default("admin")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────
// Container — Paletten / Kartons / Beutel im Wareneingang (Phase 6)
//
// Lebenszyklus:
//   open → closed → shipped → received_supplier
//
// Code-Format: `PAL-YYYY-NNNNNN` (laufende Zahl pro Jahr).
// `maxOpenUntil` = openedAt + maxAgeDays (Setting; default 14d).
//
// Events werden ins gemeinsame RetoureEvent-Log geschrieben, sobald
// Items auf einen Container gelegt werden (item_linked_to_container).
// Reine Container-Lifecycle-Events (created/closed) werden nicht ins
// RetoureEvent-Log gespiegelt, weil sie nicht an einen Case gebunden
// sind — diese Status-Übergänge sind über `openedAt` / `closedAt` /
// `status` jederzeit nachvollziehbar.
// ─────────────────────────────────────────────────────────────────────
model Container {
  id           String   @id @default(cuid())
  code         String   @unique           // PAL-<supplier-slug>-YYYY-NNNNNN
  type         String   @default("palette") // "palette" | "carton" | "bag"
  partnerId    String?                    // Phase 7 — vorerst optional/string
  /// Lieferant, an den der Container retourniert wird.
  /// Geschäftsregel: "Ein Container = 1 Lieferant." Bei der Neuanlage
  /// über die PDA-API ist das Feld Pflicht; alte Container ohne Supplier
  /// (vor dieser Migration) bleiben weiter gültig (nullable).
  supplierId   String?
  status       String   @default("open")  // "open" | "closed" | "shipped" | "received_supplier"
  openedAt     DateTime @default(now())
  closedAt     DateTime?
  maxOpenUntil DateTime?                  // openedAt + maxAgeDays (Setting)
  createdByPda String?                    // welcher PDA hat angelegt
  shippedTrackingNumber String?           // Phase 7 ergänzt das
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        RetoureItem[]              // back-relation zu RetoureItem.containerId
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([partnerId])
  @@index([supplierId])
  @@index([openedAt])
}

// ─────────────────────────────────────────────────────────────────────
// Supplier — Stammdaten der Hersteller / Lieferanten, an die Ware
// nach der Wareneingangsprüfung weiter-retourniert wird.
//
// Pro Lieferant pflegen wir Adresse, Kontaktperson, RMA-Policy
// (Freitext-Hinweise, die das Lager beim Verpacken beachten muss) und
// eine durchschnittliche "lead-time" für die Hersteller-Retoure.
// ─────────────────────────────────────────────────────────────────────
model Supplier {
  id              String   @id @default(cuid())
  name            String   @unique
  /// 2–4-stelliger Container-Code-Prefix (z. B. "IP", "AP", "KB").
  /// Optional — wenn null, leitet `supplierShortCode()` automatisch
  /// aus dem Namen ab (erste 2 Großbuchstaben).
  shortCode       String?
  /// Routing-ID auf dem Container-Label (z. B. "R01 · INTERPARTS-PL").
  /// Optional — wenn null, wird via deriveRoute() aus dem Namen abgeleitet.
  routeCode       String?
  contactPerson   String?
  email           String?
  phone           String?
  street          String?
  postalCode      String?
  city            String?
  country         String   @default("DE")
  /// Freitext-Hinweise zur Hersteller-Retoure
  /// (z. B. "Bitte Originalverpackung, Retourenschein der Marke beilegen").
  rmaPolicy       String?
  /// Typische Bearbeitungsdauer einer Hersteller-Retoure in Tagen.
  defaultLeadDays Int      @default(30)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  containerReturns SupplierReturn[]
  containers       Container[]
  retoureItems     RetoureItem[]

  @@index([active])
  @@index([name])
}

// ─────────────────────────────────────────────────────────────────────
// SupplierReturn — eine konkrete Retoure-Sendung an einen Lieferanten.
//
// Status-Maschine:
//   vorbereitet → versandt → bei_lieferant → gutschrift_erhalten
//                                          → abgelehnt
//
// `containerId` ist optional, weil manche Lieferanten-Retouren nur
// einen einzelnen Artikel betreffen (kein Sammel-Container).
// Die Relation auf Container wird bewusst NICHT als Prisma-Relation
// modelliert — das Container-Modell und die zugehörige Migration
// werden parallel von einem anderen Agent erzeugt; ein FK in dieser
// Migration würde fehlschlagen, wenn er vor der Container-Migration
// läuft. Stattdessen referenzieren wir die Container-Id als losen
// String, der von der Anwendungs-Schicht aufgelöst wird.
// ─────────────────────────────────────────────────────────────────────
model SupplierReturn {
  id             String    @id @default(cuid())
  supplierId     String
  containerId    String?   // lose String-Referenz auf Container.id (siehe Doc oben)
  trackingNumber String?
  /// "vorbereitet" | "versandt" | "bei_lieferant" | "gutschrift_erhalten" | "abgelehnt"
  status         String    @default("vorbereitet")
  shippedAt      DateTime?
  receivedAt     DateTime?
  refundedAt     DateTime?
  refundAmount   Float?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supplier       Supplier  @relation(fields: [supplierId], references: [id])

  @@index([status])
  @@index([supplierId])
  @@index([containerId])
}

// ─────────────────────────────────────────────────────────────────────
// RetourePrefill — Hand-off vom Shop (z.B. Shopware-Plugin) ins Portal
//
// Workflow:
//   1. Shopware-Plugin POSTet auf /api/retoure/prefill mit Bestelldaten.
//   2. Wir erzeugen einen kurzlebigen Token (15 Min TTL) und speichern
//      den vollen Payload als JSON-Snapshot. KEINE FK auf RetoureCase —
//      ein Prefill wird ggf. NIE in einen Case münden (Kunde bricht ab).
//   3. Antwort enthält {token, expiresAt, url} (url = …/start?token=…).
//   4. Kunde landet auf /start?token=…, sieht seine Daten read-only und
//      kann sie bestätigen. Sobald er das tut, setzen wir consumedAt
//      und leiten ihn in den normalen Customer-Flow (mit Token in der
//      URL) weiter, wo die Customer-Page die Prefill-Daten als Start-
//      State nutzen kann.
//   5. Abgelaufene/konsumierte Token können von einem späteren Cleanup
//      gelöscht werden (Index auf expiresAt).
// ─────────────────────────────────────────────────────────────────────
model RetourePrefill {
  id            String    @id @default(cuid())
  token         String    @unique
  bestellnummer String
  /// Gesamter Prefill-Body als JSON-Snapshot (orderId, customer, items,
  /// source). Wir parsen lazy beim /start-Render und legen ihn nicht in
  /// einzelne Spalten ab, weil die Felder weitgehend optional sind und
  /// sich ihr Schema im Shop noch verschieben kann.
  payloadJson   String
  source        String?
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([token])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────
// RetoureItemPhoto — Foto eines RetoureItems (Phase 5)
//
// Pro Item lädt der PDA mehrere Fotos hoch (typische Sätze: OVP +
// Artikel + Detail). Jedes Foto wird auf der Disk (UPLOAD_DIR) unter
// `retoure-photos/<caseId>/<itemId>/<photoId>.<ext>` abgelegt. Nach
// dem Upload triggert der Endpoint via `after()` einen OpenAI-Vision-
// Call (gpt-4o-mini), dessen Ergebnis als JSON in `aiAnalysisJson`
// persistiert wird: `{score:0-100, reasoning, confidence:0-1, model, runAt}`.
//
// `caseId` ist denormalisiert, damit Listings/Lookups ohne Join über
// RetoureItem möglich sind. Bei DELETE des Items werden die Fotos via
// Cascade entfernt; das physische File-Cleanup übernimmt der DELETE-
// Endpoint bzw. ein späterer Janitor-Job.
// ─────────────────────────────────────────────────────────────────────
model RetoureItemPhoto {
  id        String   @id @default(cuid())
  itemId    String
  caseId    String   // denormalisiert für schnellen Lookup
  kind      String   // "ovp" | "artikel" | "detail1" | "detail2" | "other"
  filename  String
  path      String   // Pfad unter UPLOAD_DIR
  mimeType  String
  sizeBytes Int
  aiAnalysisJson String?  // {score:0-100, reasoning, confidence:0-1, model, runAt}
  createdAt DateTime @default(now())
  item      RetoureItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([caseId])
  @@index([kind])
}

// ─────────────────────────────────────────────────────────────────────
// PdaDevice — pro PDA-Gerät ein Eintrag mit eigenem Bearer-Token.
//
// Pairing-Flow (siehe pda-auth.ts):
//   1. Admin legt im Dashboard ein neues PDA an (pdaId = Name z. B.
//      "Lager-Nord"). Backend würfelt einen langen `token` UND einen
//      kurzen `pairingCode` (~10 Zeichen, alphanumerisch).
//   2. Admin sieht einen QR-Code, der die URL
//        https://pda.rma.<env>.kfzblitz24-group.com/pda-app/pair?code=<pairingCode>
//      enthält. Pairing-Code läuft nach `pairingExpiresAt` ab (10 Min).
//   3. PDA-Gerät scannt den QR (Q900 als HID-Keyboard → tippt URL in
//      Chrome-Adresszeile + Enter), Browser landet auf /pda-app/pair.
//      Page liest `?code=` aus, POSTet an `/api/pda/pair`, bekommt
//      `{token, pdaId}` zurück und legt das in localStorage ab.
//   4. Backend setzt `pairedAt = now()` und nullt `pairingCode` —
//      Pairing-Link ist damit verbraucht.
//
// Auth (`checkPdaAuth`):
//   - Akzeptiert weiterhin den shared API_TOKEN aus env (für Admin-/
//     curl-Tests sowie Backward-Compat).
//   - Akzeptiert zusätzlich Bearer-Tokens von aktiven PdaDevice-Rows
//     (`active=true` AND `pairedAt != null`). Setzt bei jedem Treffer
//     `lastSeenAt = now()` (best-effort, non-blocking).
//
// Revoke: Admin setzt `active=false` → Token wird ab dem nächsten
// Request abgelehnt.
// ─────────────────────────────────────────────────────────────────────
model PdaDevice {
  id               String    @id @default(cuid())
  /// Friendly Name z. B. "Lager-Nord" oder "pda-01" — wird als
  /// `actor`/`createdByPda` in Events & Items gespeichert.
  pdaId            String    @unique
  /// Bearer-Token (32 hex chars). Geht beim Pairing einmalig ans
  /// Gerät und bleibt dort in localStorage.
  token            String    @unique
  active           Boolean   @default(true)
  /// Kurzcode für die QR-Pairing-URL. Nullable: nach erfolgreichem
  /// Pairing wird der Code gelöscht. UNIQUE solange gesetzt.
  pairingCode      String?   @unique
  pairingExpiresAt DateTime?
  pairedAt         DateTime?
  lastSeenAt       DateTime?
  createdBy        String?   // admin-email aus NextAuth-Session
  createdAt        DateTime  @default(now())

  @@index([token])
  @@index([active])
  @@index([pairingCode])
}

// ─────────────────────────────────────────────────────────────────────
// PendingPhoto — Customer-Photos die VOR dem Case-Submit hochgeladen
// wurden und noch nicht zugeordnet sind.
//
// Workflow:
//   1. Shop-Plugin lädt Datei via POST /api/retoure/photos/upload hoch
//   2. Wir speichern Bytes auf Disk + PendingPhoto-Row mit photoId
//   3. Plugin packt photoId in Submit-Payload (items[].photo_ids)
//   4. Beim Submit-Handler: PendingPhoto → RetoureItemPhoto promovieren
//      + PendingPhoto-Row löschen
//   5. Cron räumt nicht-referenzierte PendingPhotos > 1h alt weg
// ─────────────────────────────────────────────────────────────────────
model PendingPhoto {
  id        String   @id @default(cuid())
  /// `customer_submitted` (Standardfall) oder `customer_receipt` (Rechnungs-Scan)
  kind      String   @default("customer_submitted")
  filename  String
  path      String   // Pfad unter UPLOAD_DIR/pending/
  mimeType  String
  sizeBytes Int
  /// IP des Uploaders (Shop-Backend-Server, nicht End-Customer)
  uploaderIp String?
  /// Source-Token-Hash für Audit (welcher Shop hat hochgeladen)
  uploaderTokenHash String?
  /// Nach 1h löschen wenn nicht referenziert.
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────
// WebhookEndpoint — pro Source konfigurierbarer Empfänger.
//
// Admin legt für `source=shopware` einen Endpoint an mit URL + HMAC-
// Secret. Wenn Status-Events fired werden, suchen wir nach passendem
// Endpoint und triggern Delivery.
// ─────────────────────────────────────────────────────────────────────
model WebhookEndpoint {
  id          String   @id @default(cuid())
  /// Welche Source dieser Endpoint behandelt. UNIQUE.
  /// `shopware` für jetzt. Später ggf. `amazon` wenn Marketplace-Webhook kommt.
  source      String   @unique
  /// Vollständige URL inkl. Pfad (z. B. https://shop.kfzblitz24.de/api/kb24-retoure-webhook)
  url         String
  /// HMAC-Secret (mind. 32 chars). Wird zum Signieren genutzt.
  secret      String
  active      Boolean  @default(true)
  /// Optionale IP-Allowlist für extra Defense-in-Depth (CSV)
  allowedIps  String?
  /// Welche Events soll dieser Endpoint bekommen? CSV.
  /// Default alle drei: "status_changed,refund_decided,case_canceled"
  events      String   @default("status_changed,refund_decided,case_canceled")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveries  WebhookDelivery[]

  @@index([source])
  @@index([active])
}

// ─────────────────────────────────────────────────────────────────────
// WebhookDelivery — pro Versuch ein Row. Ermöglicht Retry, Audit,
// Manual-Replay.
//
// Lifecycle:
//   1. Event fired → ein Row mit status="pending" + scheduledAt=now()
//   2. Worker pickt sich pending+overdue Rows auf
//   3. POST an URL, response loggen, status setzen
//      - 2xx → "ok"
//      - andere → "failed" + retryCount++, nextRetryAt setzen
//   4. Nach 5 Failures: status="hard_failed" + Admin-Alert
// ─────────────────────────────────────────────────────────────────────
model WebhookDelivery {
  id          String   @id @default(cuid())
  endpointId  String
  /// Idempotency-Key der an den Shop geschickt wird (UUID).
  /// Bei Retries identisch — Shop dedupliziert.
  deliveryUuid String  @unique
  /// Welche Case betrifft das Event (für Manual-Replay UI)
  caseId      String?
  event       String   // "status_changed" | "refund_decided" | "case_canceled"
  /// JSON-Payload das wir POST'en (idempotent zwischen Retries)
  payload     String
  /// "pending" | "ok" | "failed" | "hard_failed" | "canceled"
  status      String   @default("pending")
  retryCount  Int      @default(0)
  scheduledAt DateTime
  nextRetryAt DateTime?
  lastAttemptAt DateTime?
  lastResponseCode Int?
  lastResponseBody String?
  /// Idempotency-Body bei erfolgreichem ACK (z. B. mollieRefundId)
  ackBody     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([caseId])
  @@index([event])
  @@index([deliveryUuid])
  @@index([createdAt])
}
