# Webisco daemon connection. Leave empty to run in demo mode (mock data).
# If the daemon lives on an internal network, our VPS must be able to reach
# the host:port — typically via a VPN or SSH tunnel.
WEBISCO_HOST=http://webisco.intern.kfzblitz24.de:8228
WEBISCO_USERNAME=

# Authentication — supply EITHER a customer password OR the Admin-ID.
# If WEBISCO_ADMIN_ID is set, the server skips customer password checks
# (useful for server-side operations where we don't have / want to
# ask for the customer's password).
WEBISCO_PASSWORD=
WEBISCO_ADMIN_ID=

# Set to "true" to force demo mode even when host/credentials are set.
# Useful when testing the UI without hitting the real ERP.
WEBISCO_DEMO_MODE=
