generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String? // nullable — google-sso-only users have no password
  role      String   @default("agent") // admin, agent
  active    Boolean  @default(true)
  googleId  String?  @unique // google 'sub' claim, set on first google-sso login
  imageUrl  String? // google profile picture
  createdAt DateTime @default(now())

  assignedTickets Ticket[]      @relation("Assignee")
  notes           TicketNote[]
  messages        Message[]
  reviewedDrafts  AiDraft[]     @relation("ReviewedBy")
  events          TicketEvent[]
  signature       Signature?
}

model Signature {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String // shown as name in signature
  position    String // e.g. "Kundenservice", "Administrator"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  name      String? // legacy full name, kept for backward compat & display fallback
  phone     String?
  orderRef  String? // link to Retoure/Webisco order if known
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
}

model Ticket {
  id                 String    @id @default(cuid())
  number             Int       @unique @default(autoincrement())
  code               String    @unique // 6-char alphanumeric, displayed as #CODE, used for reply-threading
  subject            String
  status             String    @default("open") // open, pending (warten auf kunde), on_hold, resolved, closed
  priority           String    @default("normal") // low, normal, high, urgent
  category           String? // shipping, returns, invoice, general, other
  contactId          String
  assigneeId         String?
  firstResponseDueAt DateTime // creation + first-response SLA
  resolutionDueAt    DateTime // creation + resolution SLA
  firstResponseAt    DateTime?
  resolvedAt         DateTime?
  snoozedUntil       DateTime?
  snoozedReason      String?
  gmailThreadId      String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  contact  Contact       @relation(fields: [contactId], references: [id])
  assignee User?         @relation("Assignee", fields: [assigneeId], references: [id])
  messages Message[]
  notes    TicketNote[]
  drafts   AiDraft[]
  events   TicketEvent[]
  orders   TicketOrder[]
  aiUsage  AiUsage[]

  @@index([status])
  @@index([assigneeId])
  @@index([firstResponseDueAt])
  @@index([snoozedUntil])
  @@index([contactId])
}

model TicketOrder {
  id                   String    @id @default(cuid())
  ticketId             String
  ref                  String // customer-facing order number, e.g. "KB24-73627372300"
  note                 String?
  source               String    @default("manual") // manual, ai_detected, webisco
  emailMatched         Boolean   @default(false) // true only when Webisco order email matches ticket contact
  status               String? // webisco order status snapshot (e.g. "abgeschlossen", "offen")
  totalBrutto          Float? // snapshot of endpreis_brutto for quick display
  webiscoData          String? // JSON snapshot of the full Beleg (positions, addresses, etc.)
  fetchedAt            DateTime? // when webiscoData was last synced
  retoureCaseId        String? // if a return was created for this order via /retoure/submit
  retoureAnmeldungUrl  String? // customer PDF (Retourenschein + Label) URL from retoure service
  retoureLabelUrl      String? // DHL label PDF URL (if label was booked)
  retoureCreatedAt     DateTime?
  retoureFreeLabel     Boolean   @default(false) // admin toggled free label (Rückgabe+)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, ref])
  @@index([ticketId])
  @@index([ref])
}

model Message {
  id              String    @id @default(cuid())
  ticketId        String
  authorUserId    String? // set for outbound messages authored by an agent
  direction       String // inbound, outbound
  kind            String    @default("reply") // reply, acknowledgement, resend
  fromEmail       String
  toEmail         String // may be a JSON array for multiple recipients
  ccEmail         String?
  subject         String?
  bodyHtml        String
  bodyText        String?
  gmailMessageId  String?   @unique
  resendMessageId String?
  messageIdHeader String? // Message-Id header value we emitted or received
  inReplyTo       String?
  aiGenerated     Boolean   @default(false)
  resentFromId    String? // FK to a prior Message that this is a resend of
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorUser  User?        @relation(fields: [authorUserId], references: [id])
  attachments Attachment[]
  resentFrom  Message?     @relation("MessageResends", fields: [resentFromId], references: [id])
  resends     Message[]    @relation("MessageResends")

  @@index([ticketId])
}

model TicketNote {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  body      String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

model Template {
  id        String   @id @default(cuid())
  name      String   @unique
  shortcode String?  @unique // typed as `::code` in composer to auto-insert
  subject   String
  bodyHtml  String
  category  String? // used for grouping in templates page + ai matching
  variables String   @default("[]") // JSON array of variable names
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiDraft {
  id               String    @id @default(cuid())
  ticketId         String
  model            String // e.g. "gpt-4o-2024-11-20"
  subject          String
  bodyHtml         String
  confidence       Float // 0..1 self-reported
  category         String?
  status           String    @default("pending") // pending, approved, rejected, sent, superseded
  autoSendEligible Boolean   @default(false)
  reviewedById     String?
  reviewedAt       DateTime?
  rejectedReason   String?
  createdAt        DateTime  @default(now())

  ticket     Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([ticketId])
  @@index([status])
}

model AiUsage {
  id               String   @id @default(cuid())
  ticketId         String?
  aiDraftId        String?
  model            String // e.g. "gpt-4o-2024-08-06"
  purpose          String   @default("draft") // draft, regenerate, other
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  cachedTokens     Int      @default(0) // prompt tokens served from cache (billed cheaper)
  inputCostUsd     Float
  outputCostUsd    Float
  totalCostUsd     Float
  latencyMs        Int?
  createdAt        DateTime @default(now())

  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([model])
  @@index([ticketId])
}

model Attachment {
  id          String   @id @default(cuid())
  messageId   String
  filename    String
  contentType String
  size        Int
  storageKey  String // legacy — path/blob-key placeholder, may be empty when content column is used
  contentId   String? // MIME Content-Id header (without <>) for inline-image cid: mapping
  inline      Boolean  @default(false) // true if attachment is referenced via cid: in bodyHtml
  content     Bytes? // raw bytes (Postgres BYTEA) — for gmail-ingested inline images + small attachments
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([contentId])
}

model TicketEvent {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String?
  type      String // created, assigned, status_changed, priority_changed, sla_breached, ai_drafted, ai_auto_sent, note_added, message_sent, message_received
  meta      String? // JSON blob
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

model GmailCursor {
  id           String    @id @default("singleton")
  historyId    String?
  lastPolledAt DateTime?
  updatedAt    DateTime  @updatedAt
}

model Setting {
  key       String   @id
  value     String // JSON encoded
  updatedAt DateTime @updatedAt
}
