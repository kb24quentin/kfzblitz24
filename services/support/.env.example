# Database
DB_PASSWORD=                # openssl rand -base64 24

# NextAuth
AUTH_SECRET=                # openssl rand -base64 32

# Resend (outbound mail)
RESEND_API_KEY=             # from resend.com dashboard
FROM_EMAIL=service@kfzblitz24.de
FROM_NAME=kfzBlitz24 Support
REPLY_TO_EMAIL=service@kfzblitz24.de

# Gmail API (inbound: read service@kfzblitz24.de via Workspace user delegation)
# 1) Create OAuth 2.0 Client in Google Cloud Console (Web app)
# 2) Add https://developers.google.com/oauthplayground as redirect URI
# 3) Use OAuth Playground to grant scope https://www.googleapis.com/auth/gmail.modify
#    while logged in as service@kfzblitz24.de → obtain refresh_token
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=service@kfzblitz24.de

# OpenAI (classification + draft replies)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Business rules
SLA_HOURS=24

# Cron / API auth (shared secret between support-cron container and app)
API_TOKEN=                  # openssl rand -hex 32
GMAIL_POLL_SECONDS=60       # how often support-cron polls gmail
SLA_POLL_SECONDS=300        # how often support-cron runs SLA-breach detection

# First admin user (auto-created via seed on first deploy)
ADMIN_EMAIL=
ADMIN_PASSWORD=             # set on first deploy; remove/rotate after
ADMIN_NAME=Admin
