generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user") // admin, user
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  activities       Activity[]
  reminders        Reminder[]
  assignedContacts Contact[] @relation("AssignedTo")
}

model Contact {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  email           String    @unique
  company         String?
  position        String?
  phone           String?
  city            String?
  notes           String?
  status          String    @default("new") // new, contacted, replied, interested, not_interested, customer
  tags            String    @default("[]")
  priority        String    @default("medium") // low, medium, high
  source          String    @default("manual") // manual, import, website
  assignedToId    String?
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignedTo       User?             @relation("AssignedTo", fields: [assignedToId], references: [id])
  emails           Email[]
  replies          Reply[]
  campaignContacts CampaignContact[]
  activities       Activity[]
  reminders        Reminder[]
}

model Activity {
  id        String   @id @default(cuid())
  contactId String
  userId    String?
  type      String   // comment, status_change, call, email_sent, note, reminder_created, contact_edited
  content   String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
}

model Reminder {
  id          String   @id @default(cuid())
  contactId   String
  userId      String
  title       String
  description String?
  dueDate     DateTime
  status      String   @default("pending") // pending, done, overdue
  createdAt   DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}

model Template {
  id        String   @id @default(cuid())
  name      String
  subject   String
  bodyHtml  String
  bodyText  String?
  variables String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaignsA        Campaign[] @relation("TemplateA")
  campaignsB        Campaign[] @relation("TemplateB")
  campaignsFollowUp Campaign[] @relation("FollowUpTemplate")
  emails            Email[]
}

model Campaign {
  id                 String   @id @default(cuid())
  name               String
  status             String   @default("draft")
  templateAId        String
  templateBId        String?
  abSplitRatio       Int      @default(50)
  sendRatePerDay     Int      @default(50)
  followUpEnabled    Boolean  @default(false)
  followUpDelayDays  Int      @default(3)
  followUpTemplateId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  templateA        Template          @relation("TemplateA", fields: [templateAId], references: [id])
  templateB        Template?         @relation("TemplateB", fields: [templateBId], references: [id])
  followUpTemplate Template?         @relation("FollowUpTemplate", fields: [followUpTemplateId], references: [id])
  emails           Email[]
  campaignContacts CampaignContact[]
}

model CampaignContact {
  id         String   @id @default(cuid())
  campaignId String
  contactId  String
  variant    String?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
}

model Email {
  id            String    @id @default(cuid())
  campaignId    String
  contactId     String
  templateId    String
  variant       String?
  subject       String
  body          String
  status        String    @default("queued")
  sentAt        DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  repliedAt     DateTime?
  resendEmailId String?
  createdAt     DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id])
  replies  Reply[]
}

model Reply {
  id          String    @id @default(cuid())
  emailId     String
  contactId   String
  fromEmail   String
  subject     String?
  body        String
  receivedAt  DateTime  @default(now())
  status      String    @default("unread")
  ourResponse String?
  respondedAt DateTime?

  email   Email   @relation(fields: [emailId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}
