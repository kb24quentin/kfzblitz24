<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Networking -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Camera — für CameraX QR-Scan (Pair) und Foto-Capture -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!--
        Honeywell-Scanner Broadcast-Decode-Permission. Wird gebraucht
        damit der `scan.rcv.message`-Receiver auf Honeywell-HS7-basierten
        PDAs (Netum Q900, Q500, …) tatsächlich Scan-Events bekommt.
        Ohne diese Permission feuert der Receiver still, ohne Daten.
    -->
    <uses-permission android:name="com.honeywell.decode.permission.DECODE" />

    <!--
        Bluetooth-Drucker (Munbyn RW403B u. Ä.). Wir verwenden Classic
        Bluetooth (SPP-Profil, RFCOMM-Socket), kein BLE. Auf Android 12+
        sind die alten BLUETOOTH/BLUETOOTH_ADMIN-Permissions ersetzt
        durch BLUETOOTH_CONNECT (verbinden zu bereits gepairten Geräten)
        und BLUETOOTH_SCAN (Discovery neuer Geräte). Wir benutzen für
        den Druck-Flow nur bereits in den System-Settings gepairte
        Drucker, daher reicht BLUETOOTH_CONNECT — Scan bleibt sicherheits-
        halber mit drin falls wir später In-App-Pairing anbieten.
        BLUETOOTH/BLUETOOTH_ADMIN sind für Android ≤ 11 (Legacy-Devices).
    -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />

    <application
        android:name=".RetourePdaApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.RetourePda"
        android:hardwareAccelerated="true">

        <!--
            ML Kit Barcode-Scanning Metadata.
            Sagt Google Play Services Bescheid dass die App das Barcode-
            Modul nutzt; falls nicht installiert, wird's nachgeladen.
        -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.RetourePda">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            IntentBroadcastScanner: Newland, Honeywell, Zebra DataWedge und
            generische chinesische PDA-Scanner senden ihre Scan-Ergebnisse
            über Broadcasts. Diese werden dynamisch zur Laufzeit registriert,
            daher kein statischer <receiver>-Eintrag nötig.

            Falls ein Vendor-SDK statische Registration erfordert (z. B. ältere
            Newland-Firmware), hier einen <receiver> Block einfügen:

            <receiver android:name=".data.scanner.IntentBroadcastScanner$StaticReceiver"
                android:exported="true">
                <intent-filter>
                    <action android:name="nlscan.action.SCANNER_RESULT"/>
                    <action android:name="com.honeywell.aidc.action.ACTION_BARCODE_DATA"/>
                    <action android:name="com.symbol.datawedge.api.RESULT_ACTION"/>
                    <action android:name="scan.rcv.message"/>
                </intent-filter>
            </receiver>
        -->

    </application>
</manifest>
